# ================================================================
# ResidEase — Backend Environment Variables
# ================================================================
# HOW TO USE:
#   1. Copy this file and rename it to ".env"
#   2. Fill in your real values below
#   3. NEVER commit .env to Git — add it to .gitignore
# ================================================================

# ── Application ──────────────────────────────────────────────────
APP_NAME=ResidEase
APP_ENV=development
APP_PORT=8080
DEBUG=True

# ── Database (MongoDB Atlas) ─────────────────────────────────────
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<AppName>
DATABASE_URL=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0
MONGODB_NAME=your-database-name

# ── JWT ──────────────────────────────────────────────────────────
# Generate a secure secret key by running:
#   python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# Or use this
#   py -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
JWT_SECRET=your-base64-encoded-secret-key-here
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

# ── Google OAuth ─────────────────────────────────────────────────
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback
FRONTEND_URL=http://localhost:5173

# ── Email (SMTP) ─────────────────────────────────────────────────
# For Gmail: use an App Password (not your real password)
# Generate at: https://myaccount.google.com/apppasswords
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_FROM=your@gmail.com
MAIL_FROM_NAME=ResidEase
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_TLS=True
MAIL_SSL=False

# ── File Storage ─────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,docx

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Payment Gateway (PayMongo) ───────────────────────────────────
# Get keys from: https://dashboard.paymongo.com/developers
PAYMENT_GATEWAY_API_KEY=pk_test_your-public-key-here
PAYMENT_GATEWAY_SECRET=sk_test_your-secret-key-here

# ── APScheduler (Cron Jobs) ──────────────────────────────────────
# Format: minute hour day month weekday
BILLING_CRON=0 0 1 * *
REMINDER_CRON=0 9 * * *
LEASE_CHECK_CRON=0 8 * * *

# ── SMS / Twilio (optional) ──────────────────────────────────────
# Get credentials from: https://console.twilio.com
SMS_ACCOUNT_SID=your-twilio-account-sid
SMS_AUTH_TOKEN=your-twilio-auth-token
SMS_FROM_NUMBER=+1234567890